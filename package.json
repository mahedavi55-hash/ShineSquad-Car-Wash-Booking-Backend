{
  "name": "shinesquad-car-wash-booking-backend",
  "version": "1.0.0",
  "description": "Backend API for ShineSquad Car Wash Booking built with clean architecture principles.",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --project tsconfig.json --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "echo 'No linter configured yet'"
  },
